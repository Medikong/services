SERVICE_NAME=auth-service
SERVICE_VERSION=dev
SERVICE_ENVIRONMENT=local

HTTP_ADDR=:8080
ADMIN_ADDR=:9090
WORKER_ADMIN_ADDR=:9092
HTTP_REQUEST_TIMEOUT=10s
READINESS_CHECK_TIMEOUT=2s
DRAIN_DELAY=5s
SHUTDOWN_TIMEOUT=15s
MIGRATION_TIMEOUT=5m

DATABASE_URL=postgres://app:app@localhost:5432/auth?sslmode=disable
POSTGRES_POOL_MAX_CONNS=10
POSTGRES_POOL_MIN_CONNS=0
POSTGRES_POOL_MIN_IDLE_CONNS=1
POSTGRES_POOL_MAX_CONN_LIFETIME=30m
POSTGRES_POOL_MAX_CONN_IDLE_TIME=30m
POSTGRES_POOL_HEALTH_CHECK_PERIOD=1m

# Required in every environment. Keep key material in a secret manager.
AUTH_CREDENTIAL_HMAC_KEY=
AUTH_REPLAY_ENCRYPTION_KEY=
AUTH_JWT_PRIVATE_KEY_PEM=
AUTH_JWT_PRIVATE_KEY_FILE=
AUTH_JWT_KEY_ID=
AUTH_JWT_ISSUER=auth-service
AUTH_JWT_AUDIENCES=dropmong-api
# JSON object: {"retiring-key-id":"-----BEGIN PUBLIC KEY-----..."}
AUTH_JWT_RETIRING_PUBLIC_KEYS=
# Ed25519 proof consumed by user-service during synchronous registration.
AUTH_PROOF_PRIVATE_KEY=
AUTH_PROOF_KEY_ID=
AUTH_USER_PROOF_PUBLIC_KEY=
AUTH_USER_PROOF_KEY_ID=
AUTH_USER_PROOF_ISSUER=user-service
AUTH_PROOF_CLOCK_SKEW=30s
AUTH_ACCESS_TTL=15m
AUTH_SESSION_TTL=24h
AUTH_REMEMBER_ME_SESSION_TTL=720h
AUTH_REFRESH_TTL=336h
AUTH_CHALLENGE_TTL=10m
AUTH_INTENT_TTL=15m
AUTH_REGISTRATION_TTL=30m
AUTH_PROOF_TTL=5m
AUTH_RECOVERY_TTL=2m
# Unicode code point 기준 12~256 범위의 최소값이다. 최대 256 code point, UTF-8 1024바이트이며 trim·정규화하지 않는다.
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_SESSION_COOKIE_NAME=__Host-dm_refresh
AUTH_FLOW_COOKIE_NAME=__Host-dm_auth
AUTH_COOKIE_SECURE=true
AUTH_ALLOWED_ORIGINS=http://localhost:3000

# Session status projection and ext_authz (Redis hit, PostgreSQL fallback)
AUTH_SESSION_STATUS_REDIS_URL=redis://localhost:6379/0
AUTH_SESSION_STATUS_CACHE_TTL=5m
AUTH_SESSION_STATUS_DB_TIMEOUT=100ms
AUTH_SESSION_STATUS_MAX_DB_LOOKUPS=32
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=1
REDIS_DIAL_TIMEOUT=3s
REDIS_READ_TIMEOUT=1s
REDIS_WRITE_TIMEOUT=1s

# Domain outbox broker adapter. Addresses and topic are deployment-owned.
AUTH_OUTBOX_BROKER_ENABLED=false
AUTH_OUTBOX_BROKERS=
AUTH_OUTBOX_TOPIC=
AUTH_OUTBOX_PUBLISH_TIMEOUT=3s

# Email/SMS provider worker. Provider credentials stay in runtime secrets.
AUTH_DELIVERY_ENABLED=false
AUTH_EMAIL_PROVIDER_URL=
AUTH_SMS_PROVIDER_URL=
AUTH_EMAIL_PROVIDER_BEARER_TOKEN=
AUTH_SMS_PROVIDER_BEARER_TOKEN=
AUTH_PROVIDER_TIMEOUT=3s
AUTH_DELIVERY_POLL_INTERVAL=250ms
AUTH_DELIVERY_LEASE=10s
AUTH_DELIVERY_BATCH_SIZE=20
AUTH_DELIVERY_MAX_ATTEMPTS=10
AUTH_DELIVERY_BASE_BACKOFF=1s
AUTH_DELIVERY_MAX_BACKOFF=30s

# Development-only virtual Email/SMS projection. Production refuses to start
# when any development gate or development secret is enabled.
AUTH_DEVELOPMENT_ENABLED=false
AUTH_DEV_ROUTE_ENABLED=false
AUTH_VIRTUAL_ADAPTERS_ENABLED=false
AUTH_DEV_ACCESS_TOKEN=
AUTH_VIRTUAL_MESSAGE_KEY=

AUDIT_BATCH_SIZE=50
AUDIT_POLL_INTERVAL=1s
AUDIT_LEASE=30s
AUDIT_PUBLISH_TIMEOUT=10s
AUDIT_MAX_ATTEMPTS=10
AUDIT_BASE_BACKOFF=1s
AUDIT_MAX_BACKOFF=1m
AUDIT_OUTBOX_RETENTION=168h
AUDIT_CLEANUP_LIMIT=1000
AUDIT_SINK_DATABASE_URL=

PPROF_ENABLED=false
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true

PYROSCOPE_ENABLED=false
PYROSCOPE_SERVER_ADDRESS=http://localhost:4040
PYROSCOPE_BASIC_AUTH_USERNAME=
PYROSCOPE_BASIC_AUTH_PASSWORD=
PYROSCOPE_TENANT_ID=
