# Local development uses only server-side fixtures for the unavailable Auth and checkout contracts.
APP_ORIGIN=http://localhost:3000
DEV_MOCK_MODE=true
SESSION_COOKIE_SECRET=replace-with-a-unique-secret-of-at-least-32-characters

# When set, Catalog calls use the existing service contract instead of the local fixture.
# CATALOG_INTERNAL_BASE_URL=http://localhost:8081

APP_ENV=local
APP_VERSION=0.1.0
