# Local development uses only server-side fixtures for the unavailable Auth and checkout contracts.
APP_ORIGIN=http://localhost:3000
DEV_MOCK_MODE=true
SELLER_PORTAL_ENABLED=true
SESSION_COOKIE_SECRET=replace-with-a-unique-secret-of-at-least-32-characters

# When set, Catalog calls use the existing service contract instead of the local fixture.
# CATALOG_INTERNAL_BASE_URL=http://localhost:8081

# Required when SELLER_PORTAL_ENABLED=true and DEV_MOCK_MODE is not true.
# SELLER_CONTEXT_INTERNAL_BASE_URL=http://seller-context:8080
# SELLER_MANAGEMENT_INTERNAL_BASE_URL=http://seller-management:8080
# SELLER_SCOPE_SIGNING_KEY=replace-with-a-unique-secret-of-at-least-32-characters
# SELLER_SCOPE_AUDIENCE=seller-management
# TRUSTED_INGRESS_SECRET=replace-with-a-unique-secret-of-at-least-32-characters

APP_ENV=local
APP_VERSION=0.1.0
