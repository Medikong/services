SERVICE_NAME=user-service
SERVICE_VERSION=dev
SERVICE_ENVIRONMENT=local
DATABASE_URL=postgres://app:app@localhost:5432/users?sslmode=disable
HTTP_ADDR=:8080
ADMIN_ADDR=:9090
HTTP_REQUEST_TIMEOUT=10s
READINESS_CHECK_TIMEOUT=2s
DRAIN_DELAY=5s
SHUTDOWN_TIMEOUT=20s
MIGRATION_TIMEOUT=5m
POSTGRES_POOL_MAX_CONNS=10
USER_ALLOWED_ORIGINS=http://localhost:3000
USER_REQUIRED_AGREEMENTS=TERMS_OF_SERVICE:2026-07-01
USER_IDEMPOTENCY_TTL=720h
USER_PROOF_TTL=5m
USER_PROOF_CLOCK_SKEW=30s
USER_DEVELOPMENT_ENABLED=false

# 운영 환경은 아래 키를 Secret으로 명시해야 합니다. local/test는 코드에
# 포함된 개발 전용 키를 사용하며 운영 환경에서는 그 기본값을 사용할 수 없습니다.
# USER_SIGNING_PRIVATE_KEY=<raw-base64-ed25519-private-key>
# USER_SIGNING_KEY_ID=user-prod-1
# AUTH_PROOF_PUBLIC_KEY=<raw-base64-ed25519-public-key>
# AUTH_PROOF_KEY_ID=auth-prod-1
# MEDIA_PROOF_PUBLIC_KEY=<raw-base64-ed25519-public-key>
# MEDIA_PROOF_KEY_ID=media-prod-1
# USER_PRIVATE_NAME_ENCRYPTION_KEY=<raw-base64-32-byte-key>

# local/test 개발 proof API를 열 때만 설정합니다.
# USER_DEVELOPMENT_ENABLED=true
# USER_DEV_ACCESS_TOKEN=<at-least-16-characters>
