SERVICE_NAME=coupon-service
SERVICE_VERSION=dev
# local/development/dev/test만 fail-closed 외부 port 기본 조립을 허용한다.
# 공유·운영 환경은 실제 외부 adapter를 주입하는 배포 composition root가 필요하다.
SERVICE_ENVIRONMENT=local

HTTP_ADDR=:8080
ADMIN_ADDR=:9090
WORKER_ADMIN_ADDR=:9092
HTTP_REQUEST_TIMEOUT=10s
COUPON_ALLOWED_ORIGINS=http://localhost:3000
READINESS_CHECK_TIMEOUT=2s
DRAIN_DELAY=5s
SHUTDOWN_TIMEOUT=15s
# HOTSPOT.A.19-03 확정 전까지 예약 기한은 환경별 운영 입력으로 둔다.
COUPON_REDEMPTION_RESERVATION_TTL=15m
COUPON_CODE_RESERVATION_TTL=15m
COUPON_CODE_HASH_KEY=replace-with-at-least-32-random-characters
COUPON_COMMAND_LEASE=30s
COUPON_IDEMPOTENCY_TTL=24h
MIGRATION_TIMEOUT=5m
PPROF_ENABLED=false

DATABASE_URL=postgres://postgres:postgres@localhost:5432/coupon?sslmode=disable
POSTGRES_POOL_MAX_CONNS=10
POSTGRES_POOL_MIN_CONNS=0
POSTGRES_POOL_MIN_IDLE_CONNS=1
POSTGRES_POOL_MAX_CONN_LIFETIME=30m
POSTGRES_POOL_MAX_CONN_IDLE_TIME=30m
POSTGRES_POOL_HEALTH_CHECK_PERIOD=1m

# Redis는 admission/cache 보조 계층이다. 활성화할 때 failure mode를 반드시 선택한다.
COUPON_REDIS_GATE_ENABLED=false
COUPON_REDIS_GATE_FAILURE_MODE=db_fallback
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=1
REDIS_DIAL_TIMEOUT=3s
REDIS_READ_TIMEOUT=1s
REDIS_WRITE_TIMEOUT=1s

# HOTSPOT.A.19-06이 확정되기 전까지 공유 환경은 아래 값을 명시적으로 주입한다.
# MaxAttempts는 자동 재시도 중단 기준이다. 발급은 승인된 최종 실패 입력을 기다리고 전달 작업은 dead-letter로 끝낸다.
COUPON_WORKER_BATCH_SIZE=1
COUPON_WORKER_POLL_INTERVAL=1s
COUPON_WORKER_LEASE=30s
COUPON_WORKER_ATTEMPT_TIMEOUT=10s
COUPON_WORKER_MAX_ATTEMPTS=10
COUPON_WORKER_BASE_BACKOFF=1s
COUPON_WORKER_MAX_BACKOFF=1m

OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true

PYROSCOPE_ENABLED=false
PYROSCOPE_SERVER_ADDRESS=http://localhost:4040
PYROSCOPE_BASIC_AUTH_USERNAME=
PYROSCOPE_BASIC_AUTH_PASSWORD=
PYROSCOPE_TENANT_ID=
