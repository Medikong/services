              "      postman.setNextRequest('Search payment root trace');",
              "    } else {",
              "      pm.collectionVariables.unset('paymentTraceSearchRetries');",
              "      pm.test('payment root trace exists for configured paymentApproveRequestId', function () { pm.expect(traceId || '').to.not.eql(''); });",
              "    }",
              "  } else {",
              "    pm.collectionVariables.set('paymentTraceId', traceId);",
              "    pm.collectionVariables.unset('paymentTraceSearchRetries');",
              "    pm.test('payment root trace exists for configured paymentApproveRequestId', function () { pm.expect(traceId).to.not.eql(''); });",
              "    const orderTraceId = pm.collectionVariables.get('orderTraceId');",
              "    pm.test('order and payment traces are distinct', function () {",
              "      pm.expect(orderTraceId).to.be.a('string').and.not.empty;",
              "      pm.expect(traceId).to.not.eql(orderTraceId);",
              "    });",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{tempoUrl}}/api/search?tags=service.name=payment-service request_id={{paymentApproveRequestId}}&limit=20",
          "host": [
            "{{tempoUrl}}"
          ],
          "path": [
            "api",
            "search"
          ],
          "query": [
            {
              "key": "tags",
              "value": "service.name=payment-service request_id={{paymentApproveRequestId}}"
            },
            {
              "key": "limit",
              "value": "20"
