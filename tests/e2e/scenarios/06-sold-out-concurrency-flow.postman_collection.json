          },
          {
            "key": "X-User-Role",
            "value": "{{userRole}}"
          },
          {
            "key": "Idempotency-Key",
            "value": "{{idempotencyKey}}-sold-out-after-release"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"dropId\": \"drop-sold-out-001\",\n  \"productId\": \"product-sold-out-001\",\n  \"quantity\": 1\n}"
        },
