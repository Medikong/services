{
  "info": {
    "_postman_id": "4e7a6b0b-78e5-44a2-9a15-8d6f2c868e0c",
    "name": "06 Sold Out Concurrency Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create stock reservation order 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.test('order is pending payment', function () { pm.expect(body.data.status).to.eql('PENDING_PAYMENT'); });",
              "pm.environment.set('releaseOrderId', body.data.id);",
              "pm.environment.set('releaseOrderAmount', String(body.data.amount));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Request-Id",
            "value": "e2e-sold-out-order-reserve-1"
          },
          {
            "key": "X-User-Id",
            "value": "{{userId}}"
          },
          {
            "key": "X-User-Role",
            "value": "{{userRole}}"
          },
          {
            "key": "Idempotency-Key",
            "value": "{{idempotencyKey}}-sold-out-reserve-1"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"dropId\": \"drop-sold-out-001\",\n  \"productId\": \"product-sold-out-001\",\n  \"quantity\": 10\n}"
        },
        "url": {
          "raw": "{{orderServiceUrl}}/orders",
          "host": [
            "{{orderServiceUrl}}"
          ],
          "path": [
            "orders"
          ]
        }
      }
    },
