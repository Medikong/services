    {
      "name": "Create order while stock is exhausted",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 409', function () { pm.response.to.have.status(409); });",
              "const body = pm.response.json();",
              "pm.test('stock is sold out', function () { pm.expect(body.error.message).to.eql('product sold out'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Request-Id",
            "value": "e2e-sold-out-order-blocked"
          },
          {
            "key": "X-User-Id",
            "value": "22222222-2222-4222-8222-222222222222"
          },
          {
            "key": "X-User-Role",
            "value": "{{userRole}}"
          },
          {
            "key": "Idempotency-Key",
            "value": "{{idempotencyKey}}-sold-out-blocked"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"dropId\": \"drop-sold-out-001\",\n  \"productId\": \"product-sold-out-001\",\n  \"quantity\": 1\n}"
        },
