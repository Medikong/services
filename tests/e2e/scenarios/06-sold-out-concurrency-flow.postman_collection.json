          "raw": "{{orderServiceUrl}}/orders",
          "host": [
            "{{orderServiceUrl}}"
          ],
          "path": [
            "orders"
          ]
        }
      }
    },
    {
      "name": "Fail stock draining payment",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code !== 201) {",
              "  const retries = Number(pm.collectionVariables.get('paymentFailureReadyRetries') || '0');",
              "  if (retries < 5) {",
              "    pm.collectionVariables.set('paymentFailureReadyRetries', String(retries + 1));",
              "    postman.setNextRequest('Fail stock draining payment');",
              "  } else {",
              "    pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "    pm.collectionVariables.unset('paymentFailureReadyRetries');",
              "  }",
              "} else {",
              "  const body = pm.response.json();",
              "  pm.test('payment is failed', function () { pm.expect(body.data.status).to.eql('FAILED'); });",
              "  pm.collectionVariables.unset('paymentFailureReadyRetries');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Request-Id",
            "value": "e2e-sold-out-payment-fail"
          },
          {
            "key": "X-User-Id",
            "value": "{{userId}}"
          },
          {
            "key": "X-User-Role",
            "value": "{{userRole}}"
          },
          {
            "key": "Idempotency-Key",
            "value": "{{idempotencyKey}}-sold-out-payment-fail"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{releaseOrderId}}\",\n  \"amount\": {{releaseOrderAmount}},\n  \"method\": \"MOCK_CARD\",\n  \"reason\": \"card_declined\"\n}"
        },
        "url": {
          "raw": "{{paymentServiceUrl}}/payments/mock-failures",
          "host": [
            "{{paymentServiceUrl}}"
          ],
          "path": [
            "payments",
            "mock-failures"
          ]
        }
      }
    },
    {
      "name": "Create order after payment failure releases stock",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code !== 201) {",
              "  const retries = Number(pm.collectionVariables.get('releasedStockRetries') || '0');",
              "  if (retries < 5) {",
              "    pm.collectionVariables.set('releasedStockRetries', String(retries + 1));",
              "    postman.setNextRequest('Create order after payment failure releases stock');",
              "  } else {",
              "    pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "    pm.collectionVariables.unset('releasedStockRetries');",
              "  }",
              "} else {",
              "  const body = pm.response.json();",
              "  pm.test('new order is pending payment', function () { pm.expect(body.data.status).to.eql('PENDING_PAYMENT'); });",
              "  pm.test('new order belongs to second user', function () { pm.expect(body.data.userId).to.eql('22222222-2222-4222-8222-222222222222'); });",
              "  pm.collectionVariables.unset('releasedStockRetries');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Request-Id",
            "value": "e2e-sold-out-order-after-release"
          },
