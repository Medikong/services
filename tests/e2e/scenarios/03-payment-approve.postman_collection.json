{
  "info": {
    "_postman_id": "7e4c57dc-fd87-41bd-ae70-b847f569f103",
    "name": "03 Payment Approve",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create order for payment",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.test('order is pending payment', function () { pm.expect(body.data.status).to.eql('PENDING_PAYMENT'); });",
              "pm.test('order id is captured', function () { pm.expect(body.data.id).to.not.eql(''); });",
              "pm.environment.set('orderId', body.data.id);",
              "pm.environment.set('orderAmount', String(body.data.amount));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Request-Id",
            "value": "e2e-payment-order-create"
          },
          {
            "key": "X-User-Id",
            "value": "{{userId}}"
          },
          {
            "key": "X-User-Role",
            "value": "{{userRole}}"
          },
          {
            "key": "Idempotency-Key",
            "value": "{{idempotencyKey}}-payment-order"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"dropId\": \"{{dropId}}\",\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}"
        },
        "url": {
          "raw": "{{orderServiceUrl}}/orders",
          "host": [
            "{{orderServiceUrl}}"
          ],
          "path": [
            "orders"
          ]
        }
      }
    },
    {
      "name": "Approve mock payment",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.test('payment is approved', function () { pm.expect(body.data.status).to.eql('APPROVED'); });",
              "pm.test('payment belongs to current order', function () { pm.expect(body.data.orderId).to.eql(pm.environment.get('orderId')); });",
              "pm.environment.set('paymentId', body.data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Request-Id",
            "value": "e2e-payment-approve"
          },
          {
            "key": "X-User-Id",
            "value": "{{userId}}"
          },
          {
            "key": "X-User-Role",
            "value": "{{userRole}}"
          },
          {
            "key": "Idempotency-Key",
            "value": "{{idempotencyKey}}-payment-approve"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"amount\": {{orderAmount}},\n  \"method\": \"MOCK_CARD\"\n}"
        },
        "url": {
          "raw": "{{paymentServiceUrl}}/payments/mock-approvals",
          "host": [
            "{{paymentServiceUrl}}"
          ],
          "path": [
            "payments",
            "mock-approvals"
          ]
        }
      }
    },
    {
      "name": "Get approved payment",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('payment id matches captured id', function () { pm.expect(body.data.id).to.eql(pm.environment.get('paymentId')); });",
              "pm.test('payment remains approved', function () { pm.expect(body.data.status).to.eql('APPROVED'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Request-Id",
            "value": "e2e-payment-get"
          },
          {
            "key": "X-User-Id",
            "value": "{{userId}}"
          },
          {
            "key": "X-User-Role",
            "value": "{{userRole}}"
          }
        ],
        "url": {
          "raw": "{{paymentServiceUrl}}/payments/{{paymentId}}",
          "host": [
            "{{paymentServiceUrl}}"
          ],
          "path": [
            "payments",
            "{{paymentId}}"
          ]
        }
      }
    }
  ]
}
